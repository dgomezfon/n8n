# ------------------------
# POSTGRES
# ------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=n8n

POSTGRES_NON_ROOT_USER=n8n_user
POSTGRES_NON_ROOT_PASSWORD=n8n_pass

# ------------------------
# N8N CORE
# ------------------------
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678

N8N_EDITOR_BASE_URL=http://localhost
N8N_WEBHOOK_URL=http://localhost

# ------------------------
# SECURITY
# ------------------------
N8N_SECURE_COOKIE=false
N8N_USER_MANAGEMENT_ENABLED=true
N8N_BASIC_AUTH_ACTIVE=false

# IMPORTANT: change this with a real secret key
N8N_ENCRYPTION_KEY=my-super-secret-key-123

# ------------------------
# MISC
# ------------------------
GENERIC_TIMEZONE=America/Bogota
